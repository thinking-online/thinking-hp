      const wait = getTeaser(q,val) ? 1250 : 420;
      advanceTimer=setTimeout(()=>{ advanceTimer=null; goTo(i+1); }, wait);
    });
  });
}

function getTeaser(q,val){
  if(!q.teaser) return null;
  return q.teaser[val] || q.teaser._all || null;
}
function showTeaser(q,val){
  const msg=getTeaser(q,val);
  if(!msg) return;
  clearTimeout(teaserTimer);
  teaserEl.innerHTML=`<span class="tz-icon">🔍</span>${msg}`;
  teaserEl.classList.add("show");
  teaserTimer=setTimeout(()=>teaserEl.classList.remove("show"), 1500);
}

function showScreen(name){
  main.querySelectorAll(".screen").forEach(s=>{
    s.classList.remove("active");
    if(s.dataset.screen===name){ s.classList.add("active"); s.scrollTop=0; }
  });
}

function goTo(i){
  currentIdx=i;
  if(i>=QUESTIONS.length){ startCalc(); return; }
  renderQuestion(i);
  showScreen("q"+i);
  updateChrome();
}

function updateChrome(){
  const total=QUESTIONS.length;
  if(currentIdx>=0 && currentIdx<total){
    pbarFill.style.width=(currentIdx/total*100)+"%";
    progressText.textContent=`Q${currentIdx+1} / ${total}`;
    backBtn.classList.toggle("show", currentIdx>0);
    meter.classList.remove("hidden");
  }else if(currentIdx>=total){
    pbarFill.style.width="100%";
    progressText.textContent="";
    backBtn.classList.remove("show");
  }else{
    pbarFill.style.width="0%";
    progressText.textContent="";
    backBtn.classList.remove("show");
    meter.classList.add("hidden");
  }
}

/* ---- レンジメーター ---- */
const bandWd=document.getElementById("bandWd");
const bandHd=document.getElementById("bandHd");
const valWd=document.getElementById("valWd");
const valHd=document.getElementById("valHd");
const meterNote=document.getElementById("meterNote");
const meterLabel=document.getElementById("meterLabel");

function updateMeter(){
  const r=rangeEstimate(answers);
  setBand(bandWd,valWd,r.wMin,r.wMax);
  setBand(bandHd,valHd,r.hMin,r.hMax);
  const wLocked=(r.wMin===r.wMax), hLocked=(r.hMin===r.hMax);
  if(wLocked&&hLocked){
    meterLabel.textContent="あなたのMIN 確定";
    meterNote.innerHTML=`<b>数字が確定しました。</b>残りの質問で「実現できるか」を判定します`;
  }else{
    meterLabel.textContent="あなたのMIN 予測レンジ";
    const remain=OPTION_VALUES && ["grade","club","target","gap"].filter(k=>answers[k]===undefined).length;
    meterNote.innerHTML= remain>0
      ? `あと <b>${remain}問</b> で数字が確定します`
      : `<b>数字が確定しました。</b>残りの質問で「実現できるか」を判定します`;
  }
}
function setBand(band,valEl,min,max){
  const locked=(min===max);
  const left=(min/TRACK_MAX)*100;
  const width=Math.max(((max-min)/TRACK_MAX)*100, locked?0:4);
  band.style.left=left+"%";
  band.style.width=(locked?3.5:width)+"%";
  band.classList.toggle("locked",locked);
  valEl.classList.toggle("locked",locked);
  valEl.innerHTML= locked
    ? `${fmt(min)}<small>h 確定</small>`
    : `${fmt(min)}〜${fmt(max)}<small>h</small>`;
}
function resetMeter(){
  updateMeter();
}

/* ---- 計測 → 結果 ---- */
const CALC_LINES=[
  ["基礎ラインを確認中…","学年 × 部活の表と照合しています"],
  ["4つの補正を計算中…","志望校レベルと現在地を反映しています"],
  ["実現可能性を判定中…","あなたの生活時間と照合しています"]
];
function startCalc(){
  showScreen("calc"); updateChrome();
  const ct=document.getElementById("calcText"), cs=document.getElementById("calcSub");
  let li=0;
  ct.textContent=CALC_LINES[0][0]; cs.textContent=CALC_LINES[0][1];
  const iv=setInterval(()=>{
    li++;
    if(li<CALC_LINES.length){ ct.textContent=CALC_LINES[li][0]; cs.textContent=CALC_LINES[li][1]; }
    else{ clearInterval(iv); showResult(); }
  },650);
}

function showResult(){
  const r=calc(answers);
  meter.classList.add("hidden");
  teaserEl.classList.remove("show");
  showScreen("result");

  countUp(document.getElementById("rWeekday"), r.minWd);
  countUp(document.getElementById("rHoliday"), r.minHd);

  document.getElementById("typeLine").innerHTML=`あなたは <b>${r.type.name}</b> ── ${r.type.desc}`;

  const stamp=document.getElementById("stamp");
  document.getElementById("stampName").textContent=r.type.name;
  stamp.classList.remove("on"); void stamp.offsetWidth; stamp.classList.add("on");

  const rn=document.getElementById("retireNote");
  if(r.afterRetire){
    rn.style.display="block";
    rn.innerHTML=`<b>📌 引退後のMIN：平日 ${fmt(r.afterRetire.wd)}時間 ／ 休日 ${fmt(r.afterRetire.hd)}時間</b><br>引退した翌週から、この数字に乗り換えてください。`;
  }else rn.style.display="none";

  const total=Math.max(r.minWd, r.capacity, 0.1);
  const segDesk=document.getElementById("segDesk");
  const segSlack=document.getElementById("segSlack");
  const segGap=document.getElementById("segGap");
  segDesk.style.width="0%"; segSlack.style.width="0%"; segGap.style.width="0%";
  requestAnimationFrame(()=>{ requestAnimationFrame(()=>{
    segDesk.style.width=(Math.min(r.desk,r.minWd)/total*100)+"%";
    segSlack.style.width=(Math.min(r.slackH, Math.max(0,r.minWd-r.desk))/total*100)+"%";
    segGap.style.width=(r.shortage/total*100)+"%";
  });});
  const fm=document.getElementById("feasMsg");
  if(r.shortage<=0){
    fm.className="feas-msg ok";
    fm.innerHTML=`✅ いまの生活時間でMINは達成可能です。<span>あとは「いつやるか」を固定するだけ。下のポイントを読んでください。</span>`;
  }else{
    fm.className="feas-msg warn";
    fm.innerHTML=`⚠️ このままだと平日 ${fmt(r.shortage)}時間 足りません。<span>ただし打ち手はあります。ポイント①が回収プランです。</span>`;
  }

  const pts=buildPoints(answers,r);
  document.getElementById("pointsList").innerHTML=pts.map((p,i)=>`
    <div class="point">
      <span class="pn">${i+1}</span>
      <div class="pt-body"><b>${p.t}</b><p>${p.d}</p></div>
    </div>`).join("");

  updateChrome();
}

function countUp(el,to){
  const dur=900,t0=performance.now();
  function tick(t){
    const p=Math.min(1,(t-t0)/dur);
    const e=1-Math.pow(1-p,3);
    el.textContent=fmt(round5(to*e));
    if(p<1) requestAnimationFrame(tick); else el.textContent=fmt(to);
  }
  requestAnimationFrame(tick);
}

/* ---- ナビ ---- */
document.getElementById("startBtn").addEventListener("click",()=>{ resetMeter(); goTo(0); });
backBtn.addEventListener("click",()=>{
  if(advanceTimer){ clearTimeout(advanceTimer); advanceTimer=null; }
  if(currentIdx>0) goTo(currentIdx-1);
});
document.getElementById("retryBtn").addEventListener("click",()=>{
  Object.keys(answers).forEach(k=>delete answers[k]);
  currentIdx=-1; showScreen("start"); updateChrome();
  window.scrollTo(0,0);
});
</script>
