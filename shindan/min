const OPTION_VALUES = {
  grade:["c2","c3","h1","h2","h3"],
  club:["none","light","heavy","retire"],
  target:["top","upper","mid","undecided"],
  gap:["g10","g5","g0","gnone"]
  // desk/slack はMINに影響しないためレンジ計算から除外
};

function isJHS(a){ return a.grade==="c2"||a.grade==="c3"; }

/* ================= 計算ロジック ================= */
function calc(a){
  const clubOn = (a.club==="light"||a.club==="heavy"||a.club==="retire");
  const col = clubOn ? "club" : "none";
  const useTopRow = (a.grade==="h3" && a.target==="top");
  const row = useTopRow ? BASE.top : BASE[a.grade||"h2"];
  let wd = row[col][0];
  let hd = row[col][1];

  let adj = 0, adjWd = 0, adjHd = 0;

  if(a.target==="top" && !useTopRow){ adjWd+=1; adjHd+=1; adj+=1; }
  else if(a.target==="upper"){ adjWd+=.5; adjHd+=.5; adj+=.5; }
  else if(a.target==="undecided"){ adjWd+=.5; adjHd+=.5; adj+=.5; }
  else if(a.target==="top" && useTopRow){ adj+=1; }

  if(a.gap==="g10"){ adjWd+=1; adjHd+=1; adj+=1; }
  else if(a.gap==="g5"||a.gap==="gnone"){ adjWd+=.5; adjHd+=.5; adj+=.5; }

  if(a.club==="heavy"){ adjHd+=.5; adj+=.5; }

  let minWd = round5(wd+adjWd);
  let minHd = round5(hd+adjHd);
  minHd = Math.min(minHd, 10);
  if(minHd < minWd) minHd = minWd;

  let afterRetire = null;
  if(a.club==="retire"){
    const r2 = useTopRow ? BASE.top : BASE[a.grade];
    afterRetire = {
      wd: round5(r2.none[0]+adjWd),
      hd: Math.min(round5(r2.none[1]+adjHd),10)
    };
    if(afterRetire.hd < afterRetire.wd) afterRetire.hd = afterRetire.wd;
  }

  let type;
  if(adj<=0.5) type={name:"貯金型",key:"savings",desc:"量より「継続日数」で勝つタイプ"};
  else if(adj<=1.5) type={name:"標準型",key:"standard",desc:"休日の使い方で合否が分かれるタイプ"};
  else type={name:"逆転型",key:"reversal",desc:"根性ではなく「順番」で勝つタイプ"};

  const desk = a.desk ?? 0;
  const slackH = a.slack==="s60" ? 1 : a.slack==="s30" ? .5 : 0;
  const capacity = desk + slackH;
  const shortage = Math.max(0, round5(minWd - capacity));

  return {minWd,minHd,adj,type,afterRetire,desk,slackH,capacity,shortage,useTopRow};
}
function round5(x){ return Math.round(x*2)/2; }
function fmt(x){ return (x%1===0) ? String(x) : x.toFixed(1); }

/* ---- 予測レンジ：未回答の全組み合わせを列挙してmin/maxを取る ---- */
function rangeEstimate(a){
  const keys=Object.keys(OPTION_VALUES);
  let combos=[{}];
  for(const k of keys){
    const vals = a[k]!==undefined ? [a[k]] : OPTION_VALUES[k];
    const next=[];
    for(const c of combos) for(const v of vals) next.push(Object.assign({},c,{[k]:v}));
    combos=next;
  }
  let wMin=99,wMax=0,hMin=99,hMax=0;
  for(const c of combos){
    const r=calc(c);
    if(r.minWd<wMin)wMin=r.minWd; if(r.minWd>wMax)wMax=r.minWd;
    if(r.minHd<hMin)hMin=r.minHd; if(r.minHd>hMax)hMax=r.minHd;
  }
  return {wMin,wMax,hMin,hMax};
}

