    <div class="opts">${opts}</div>`;
  sec.querySelectorAll(".opt").forEach(btn=>{
    btn.addEventListener("click",()=>{
      if(advanceTimer) return; // 連打防止
      sec.querySelectorAll(".opt").forEach(b=>b.classList.remove("selected"));
      btn.classList.add("selected");
      const val=JSON.parse(btn.dataset.val);
